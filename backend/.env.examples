# ─────────────────────────────────────────────
# RAG PDF App — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Flask Core ─────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
JWT_SECRET_KEY=change-me-to-another-random-64-char-string

# ── Frontend URL (used in email links + CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# For Docker Compose use:  postgresql://raguser:ragpassword@db:5432/ragapp
# For local dev use:       postgresql://raguser:ragpassword@localhost:5432/ragapp
# SQLite fallback (no setup needed): sqlite:///rag_app.db
DATABASE_URL=sqlite:///rag_app.db

# ── Redis ──────────────────────────────────────────────────────────────────
# For Docker Compose: redis
# For local dev:      localhost
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if Redis has no password (local dev)
REDIS_PASSWORD=

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
# Options: gpt-3.5-turbo  |  gpt-4  |  gpt-4-turbo-preview
OPENAI_MODEL=gpt-3.5-turbo
# Embedding model (do not change unless you know what you're doing)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ── AWS S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=your-rag-pdf-bucket
AWS_REGION=us-east-1

# ── Email / SMTP ───────────────────────────────────────────────────────────
# Gmail: use an App Password (not your real password)
#   → Google Account → Security → 2FA → App Passwords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ── Google OAuth 2.0 ───────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com

# ── Vector Store (FAISS) ───────────────────────────────────────────────────
# Where FAISS index files are saved on disk
VECTOR_STORE_DIR=/tmp/vector_stores

# ── File Upload Limits ─────────────────────────────────────────────────────
MAX_CONTENT_LENGTH=52428800
# 50 MB = 52428800 bytes